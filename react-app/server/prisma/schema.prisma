generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())

  email        String   @unique
  username     String   @unique
  passwordHash String

  firstName    String
  lastName     String
  birthDate    String
  course       String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}